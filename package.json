{
  "name": "ductmanage-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "DuctManage — MVAC air-duct installation progress PWA (Solution G: no-backend / local-first / event-sourced).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "verify:domain": "tsx scripts/verify-domain.ts",
    "verify:persistence": "tsx scripts/verify-persistence.ts",
    "verify:coords": "tsx scripts/verify-coords.ts",
    "verify:catalog": "tsx scripts/verify-catalog.ts",
    "verify": "npm run verify:domain && npm run verify:persistence && npm run verify:coords && npm run verify:catalog"
  },
  "dependencies": {
    "dexie": "^4.0.10",
    "konva": "^9.3.16",
    "pdfjs-dist": "^4.7.76",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.10",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "fake-indexeddb": "^6.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.20.5"
  }
}
